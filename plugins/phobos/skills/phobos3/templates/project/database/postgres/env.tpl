# Database (PostgreSQL)
DB_CONNECTION=main
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE={{DB_DATABASE}}
DB_USERNAME=postgres
DB_PASSWORD=
# Schema real dentro de la base (en Postgres NO es lo mismo que la base)
DB_SCHEMA={{SCHEMA}}
DB_TIMEZONE=UTC
DB_ENCODING=UTF8
# disable | allow | prefer | require | verify-ca | verify-full
DB_SSLMODE=prefer